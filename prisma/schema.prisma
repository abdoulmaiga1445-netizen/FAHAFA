generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Required Models ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ─────────────────────────────────────────────────────

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  name            String
  password        String
  role            String       @default("CLIENT") // CLIENT, SUPERMARCHE_ADMIN, SUPER_ADMIN
  phone           String?
  avatar          String?
  supermarcheId   String?      // ID du supermarché si role = SUPERMARCHE_ADMIN
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  accounts        Account[]
  sessions        Session[]
  managedStore    Supermarket? @relation("StoreAdmin", fields: [supermarcheId], references: [id])
  ownedStore      Supermarket? @relation("StoreOwner")
  cart            Cart?
  orders          Order[]
}

model Supermarket {
  id                  String    @id @default(cuid())
  name                String
  slug                String    @unique
  description         String?
  logo                String?
  coverImage          String?
  address             String
  commune             String
  latitude            Float
  longitude           Float
  phone               String?
  email               String?
  isOpen              Boolean   @default(true)
  isActive            Boolean   @default(true) // soft delete
  rating              Float     @default(0)
  horaires            String    @default("{}") // JSON: { "lundi": { "open": "08:00", "close": "20:00" }, ... }
  fraisLivraison      Float     @default(1000)
  livraisonGratuiteDes Float    @default(0)    // montant à partir duquel la livraison est gratuite
  livraisonDisponible Boolean   @default(true)
  rayonLivraisonKm    Float     @default(10)
  moyensPaiement      String    @default("[]") // JSON: ["Orange Money", "Wave", ...]
  ownerId             String    @unique
  owner               User      @relation("StoreOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  admins              User[]    @relation("StoreAdmin")
  products            Product[]
  categories          Category[]
  orders              Order[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Category {
  id            String      @id @default(cuid())
  name          String
  icon          String?
  supermarketId String
  supermarket   Supermarket  @relation(fields: [supermarketId], references: [id], onDelete: Cascade)
  products      Product[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Product {
  id            String      @id @default(cuid())
  name          String
  description   String?
  price         Float
  comparePrice  Float?
  image         String?
  images        String      @default("[]") // JSON array of image URLs/base64
  unit          String      @default("unité")
  stock         Int         @default(0)
  inStock       Boolean     @default(true)
  isActive      Boolean     @default(true) // soft delete
  codeBarres    String?
  supermarketId String
  supermarket   Supermarket @relation(fields: [supermarketId], references: [id], onDelete: Cascade)
  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id])
  cartItems     CartItem[]
  orderItems    OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  status          String      @default("EN_ATTENTE")
  typeCommande    String      @default("LIVRAISON") // LIVRAISON ou CLICK_AND_COLLECT
  methodePaiement String      @default("CASH") // ORANGE_MONEY, MTN_MONEY, WAVE, CASH
  total           Float
  deliveryFee     Float       @default(0)
  deliveryAddress String
  commune         String
  phone           String
  notes           String?
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  supermarketId   String
  supermarket     Supermarket @relation(fields: [supermarketId], references: [id])
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}
